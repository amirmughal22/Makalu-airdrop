{
  "name": "makalu-airdrop",
  "private": true,
  "version": "1.0.0",
  "overrides": {
    "postcss": "^8.5.10"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:worker": "node scripts/build-worker.mjs",
    "verify:worker": "node scripts/verify-worker-build.mjs",
    "build:all": "npm run build && npm run build:worker && npm run verify:worker",
    "start": "node server.js",
    "lint": "eslint .",
    "db:check": "node --env-file=.env scripts/check-db-connection.js",
    "jobs:migrate-to-db": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/migrate-jobs-json-to-db.ts",
    "worker": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/airdrop-worker.ts",
    "worker:queue": "node ./node_modules/tsx/dist/cli.mjs scripts/airdrop-queue-worker.ts",
    "worker:queue:pm2": "npx pm2 start ecosystem.config.cjs",
    "worker:queue:pm2:stop": "npx pm2 stop makalu-queue-worker",
    "wallets:generate": "node ./node_modules/tsx/dist/cli.mjs scripts/wallet-generation-worker.ts",
    "worker:queue:dist": "node dist/worker/airdrop-queue-worker.cjs",
    "worker:self-test": "node ./node_modules/tsx/dist/cli.mjs scripts/worker-self-test.ts",
    "queue:test": "node ./node_modules/tsx/dist/cli.mjs scripts/queue-test.ts",
    "queue:process-once": "node ./node_modules/tsx/dist/cli.mjs scripts/queue-process-once.ts",
    "worker:watchdog": "node ./node_modules/tsx/dist/cli.mjs scripts/worker-watchdog.ts",
    "production:start": "bash scripts/production-start.sh",
    "migrate-old-jobs": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/migrate-old-jobs.ts",
    "queue:admin": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/queue-admin.ts",
    "queue:diagnose": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/queue-admin.ts diagnose",
    "bench:pending-count": "node --env-file=.env scripts/benchmark-pending-count.mjs",
    "bench:queue-claim": "node --env-file=.env scripts/bench-queue-claim.mjs"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "ioredis": "^5.8.2",
    "pg": "^8.16.3",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "viem": "^2.47.10"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "pm2": "^6.0.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/pg": "^8.15.5",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
