# Copy to .env and fill in values (never commit real secrets).

# PostgreSQL — primary application database (Coolify: use internal service URL)
DATABASE_URL=postgresql://user:password@postgres-host:5432/database

# Optional: build DATABASE_URL from discrete vars (see database-url.js)
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=app
# DB_PASSWORD=
# DB_DATABASE=makalu

# Redis — optional cache for queue runtime flags (graceful fallback if unset or down)
REDIS_URL=redis://redis-host:6379

# --- Queue v2 (normalized job_wallets + SKIP LOCKED) ---
# Required for queue worker and normalized APIs
AIRDROP_QUEUE_V2=true

# Wallets claimed per BEGIN…COMMIT claim (default 48, max 500). Higher = fewer DB round-trips per wallet.
# Rule of thumb: (AIRDROP_DB_CONNECTION_LIMIT × worker processes) should stay below Postgres max_connections.
AIRDROP_QUEUE_BATCH_SIZE=48

# Idle poll when no rows to claim (default 500 ms, 50–60000)
AIRDROP_QUEUE_WORKER_POLL_MS=500

# Optional: extra sleep after each successful batch (0–300000 ms) to ease RPC/DB under stress
# AIRDROP_QUEUE_WORKER_INTER_BATCH_SLEEP_MS=0

# Max send attempts per wallet row = AIRDROP_QUEUE_MAX_RETRIES + 1 (retries default 5)
# AIRDROP_QUEUE_MAX_RETRIES=5

# Stuck `processing` rows reset to `pending` after this age (default 600000 ms = 10 min)
# AIRDROP_QUEUE_STALE_PROCESSING_MS=600000

# When true, shrink parallel waves after a batch with many failures (RPC relief)
# AIRDROP_QUEUE_ADAPTIVE_PARALLEL=false

# Retry backoff ladder in ms (comma-separated)
# AIRDROP_QUEUE_RETRY_BACKOFF_MS=5000,30000,300000

# Rows per INSERT when creating large jobs (default 1000)
# AIRDROP_QUEUE_BULK_CHUNK=1000

# Global drain: workers claim nothing while true
# AIRDROP_QUEUE_GLOBAL_PAUSED=false

# --- DB pool (shared by Next.js API and workers) ---
# Default 8 per process (was 16). Sum(pool max × processes) must stay under Postgres max_connections.
# `npm run wallets:generate` sets 4 when this variable is unset after loading .env (override in Coolify if needed).
AIRDROP_DB_CONNECTION_LIMIT=8
# AIRDROP_DB_IDLE_TIMEOUT_MS=30000
# AIRDROP_DB_CONNECT_TIMEOUT_MS=10000

# --- Per-batch EVM / RPC (env fallback when Dashboard queue_runtime_settings row is absent) ---
# Max simultaneous on-chain sends per wave, capped at distinct signers in the batch (nonce safety).
# Dashboard `max_parallel_txs` (1–20) overrides when set in DB.
AIRDROP_MAX_PARALLEL_TXS=6

# Pause between signer waves (ms, default 300) — reduces RPC burstiness
# AIRDROP_INTER_CHUNK_MS=300

# RPC retry ladder for transient errors
# AIRDROP_RPC_RETRY_ATTEMPTS=6
# AIRDROP_RPC_RETRY_BASE_MS=700

# --- Worker process identity / deployment ---
# Stable id per PM2/Coolify worker instance (recommended when running multiple workers)
# AIRDROP_WORKER_ID=queue-worker-1
# PM2 only: fork count for ecosystem.config.cjs (each fork gets AIRDROP_WORKER_ID + "-" + instance index)
# PM2_QUEUE_INSTANCES=20

# Separate queue worker process: set false on web when using `npm run worker:queue` only
# AIRDROP_EMBEDDED_QUEUE_WORKER=false

# Legacy JSON job runner in Next — not the normalized queue worker
# AIRDROP_EMBEDDED_WORKER=true

# Fail startup if queue indexes / runtime row checks fail
# AIRDROP_QUEUE_STRICT_STARTUP=false

# Diagnostics
# AIRDROP_QUEUE_RUNTIME_DIAG=1
# AIRDROP_QUEUE_WORKER_DEBUG=1
# AIRDROP_QUEUE_SQL_EXPLAIN=1

# --- Generated wallet batches (Dashboard → Wallet batches) ---
# Stores recipient addresses only (no private keys). `npm run wallets:generate` does not require AIRDROP_WALLET_STORAGE_SECRET.
# Optional: reserved for wallet-field-crypto helpers if you add encrypted fields later.
# AIRDROP_WALLET_STORAGE_SECRET=
# Insert chunk size for `npm run wallets:generate` (100–5000, default 5000)
# WALLET_GENERATION_BATCH_SIZE=5000
# Max wallets per batch row / POST create (1–10000000, default 1000000)
# WALLET_GENERATION_MAX_WALLETS=1000000
